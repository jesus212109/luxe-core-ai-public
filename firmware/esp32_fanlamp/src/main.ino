// -- Xiaomi sensor --
static const char* SENSOR_ADDR = "a4:c1:38:84:03:1c";
static BLEUUID serviceUUID("ebe0ccb0-7a0a-4b0c-8a1a-6ff2997da3a6");
static BLEUUID charUUID("ebe0ccc1-7a0a-4b0c-8a1a-6ff2997da3a6");

void broadcast(const uint8_t* raw) {
    std::string s((const char*)raw, 31);
    BLEAdvertisementData ad;
    ad.addData(s);
    BLEDevice::getAdvertising()->stop();
    delay(20);
    BLEDevice::getAdvertising()->setAdvertisementData(ad);
    BLEDevice::getAdvertising()->start();
}

void sendPair(const uint8_t* g1, const uint8_t* g2) {
    for (int i = 0; i < 3; i++) {
        broadcast(g1);
        delay(200);
        broadcast(g2);
        delay(200);
    }
    BLEDevice::getAdvertising()->stop();
}

bool tryConnectToSensor(BLEAddress addr) {
    BLEClient* client = BLEDevice::createClient();
    if (!client->connect(addr)) {
        client->disconnect();
        delete client;
        return false;
    }

    BLERemoteService* svc = client->getService(serviceUUID);
    if (!svc) {
        client->disconnect();
        delete client;
        return false;
    }

    BLERemoteCharacteristic* ch = svc->getCharacteristic(charUUID);
    if (!ch) {
        client->disconnect();
        delete client;
        return false;
    }

    std::string val = ch->readValue();
    if (val.length() >= 5) {
        int16_t tempRaw = (int16_t)((uint8_t)val[0] | ((uint8_t)val[1] << 8));
        float temp = tempRaw / 100.0f;
        int hum = (uint8_t)val[2];
        int bat = (uint16_t)((uint8_t)val[3] | ((uint8_t)val[4] << 8));
        Serial.printf("{\"connected\":true,\"temperature_c\":%.1f,\"humidity_pct\":%d,\"battery_mv\":%d}\n", temp, hum, bat);
    } else {
        Serial.printf("{\"connected\":true,\"error\":\"short_data:%d\"}\n", val.length());
    }

    client->disconnect();
    delete client;
    return true;
}

void scanSensor() {
    BLEDevice::getAdvertising()->stop();
    delay(100);

    BLEScan* scanner = BLEDevice::getScan();
    scanner->setActiveScan(true);
    scanner->setInterval(100);
    scanner->setWindow(99);

    bool found = false;
    BLEAddress sensorAddr("");

    // Try up to 3 scan+connect cycles
    for (int attempt = 0; attempt < 3; attempt++) {
        BLEScanResults results = scanner->start(3, true);
        int count = results.getCount();

        for (int i = 0; i < count; i++) {
            BLEAdvertisedDevice d = results.getDevice(i);
            if (strcasecmp(d.getAddress().toString().c_str(), SENSOR_ADDR) == 0) {
                found = true;
                sensorAddr = d.getAddress();
                int rssi = d.getRSSI();
                Serial.printf("{\"detected\":true,\"attempt\":%d,\"rssi\":%d}\n", attempt + 1, rssi);

                if (tryConnectToSensor(sensorAddr)) {
                    scanner->clearResults();
                    delay(100);
                    esp_restart();
                    return;
                }

                Serial.printf("{\"connect_retry\":%d}\n", attempt + 1);
                delay(500);
                break;
            }
        }

        if (!found) {
            Serial.printf("{\"scanning_retry\":%d}\n", attempt + 1);
        }

        found = false;
    }

    Serial.println("{\"detected\":false,\"error\":\"not_found_after_3_attempts\"}");
    scanner->clearResults();
    delay(100);
    esp_restart();
}

void setup() {
    Serial.begin(115200);
    delay(500);
    BLEDevice::init("C21-61A");
    Serial.println("OK");
}

void loop() {
    if (Serial.available()) {
        char cmd = Serial.read();
        switch (cmd) {
            case '0': Serial.println("off"); sendPair(OFF_G1, OFF_G2); break;
            case '1': Serial.println("sp1"); sendPair(SP1_G1, SP1_G2); break;
            case '2': Serial.println("sp2"); sendPair(SP2_G1, SP2_G2); break;
            case '3': Serial.println("sp3"); sendPair(SP3_G1, SP3_G2); break;
            case '4': Serial.println("sp4"); sendPair(SP4_G1, SP4_G2); break;
            case '5': Serial.println("sp5"); sendPair(SP5_G1, SP5_G2); break;
            case 'f': Serial.println("fan_on"); sendPair(FAN_ON_G1, FAN_ON_G2); break;
            case 'F': Serial.println("fan_off"); sendPair(FAN_OFF_G1, FAN_OFF_G2); break;
            case 'l': Serial.println("light_on"); sendPair(LIGHT_ON_G1, LIGHT_ON_G2); break;
            case 'L': Serial.println("light_off"); sendPair(LIGHT_OFF_G1, LIGHT_OFF_G2); break;
            case 'n': Serial.println("night"); sendPair(NIGHT_G1, NIGHT_G2); break;
            case 's': scanSensor(); break;
        }
    }
    delay(10);
}
