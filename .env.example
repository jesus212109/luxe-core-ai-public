# =============================================================================
# Luxe Core AI — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: This file is for the PUBLIC release. Real credentials are in the
# private repository (main-private branch).
# =============================================================================

# --- Telegram Bot ---
# Get a token from https://t.me/botfather
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Tuya Smart Plug (local LAN control) ---
# These values come from the Tuya IoT Platform (https://iot.tuya.com)
# after pairing the device via the Smart Life app and running:
#   python -m tinytuya wizard
# TUYA_DEVICE_ID=your_device_id_here
# TUYA_LOCAL_KEY=your_local_key_here
# TUYA_PLUG_IP=192.168.1.100
